     def _collect_blocking_ids(self, artifacts: list[SealedArtifact]) -> list[str]:
         ids: list[str] = []
         for a in artifacts:
             for bid in (a.parsed.get("blocking_objections") or []):
                 ids.append(bid)
         return ids
 
